    email: wootilehq@gmail.com
repository-code: "https://github.com/AnnCYW-cm/QuantMill"
url: "https://github.com/AnnCYW-cm/QuantMill"
license: MIT
version: 0.1.0
date-released: 2026-07-06
keywords:
  - quantitative-finance
  - backtesting
  - cross-sectional
  - factor-investing
  - deflated-sharpe-ratio
  - overfitting
  - A-share
